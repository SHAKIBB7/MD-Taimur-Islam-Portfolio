// Prisma schema — single source of truth for all portfolio content.
// Every content type is a model so the UI adapts automatically as data grows.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id          String       @id @default(cuid())
  name        String
  headline    String
  summary     String
  location    String
  email       String
  phone       String?
  avatarUrl   String?
  resumeUrl   String?
  availability String?
  socials     SocialLink[]
  languages   Language[]
  interests   Interest[]
  updatedAt   DateTime     @updatedAt
}

model SocialLink {
  id        String  @id @default(cuid())
  platform  String
  label     String
  url       String
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Language {
  id        String  @id @default(cuid())
  name      String
  level     String // e.g. "Native", "B2"
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Interest {
  id          String  @id @default(cuid())
  title       String
  description String?
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String    @id @default(cuid())
  role        String
  company     String
  companyUrl  String?
  location    String
  employment  String // e.g. "Internship", "Full-time"
  sector      String?
  startDate   DateTime
  endDate     DateTime?
  highlights  String[] // bullet points
  sortOrder   Int       @default(0)
}

model Education {
  id          String    @id @default(cuid())
  degree      String
  institution String
  institutionUrl String?
  location    String
  field       String
  grade       String?
  thesis      String?
  startDate   DateTime
  endDate     DateTime?
  sortOrder   Int       @default(0)
}

enum SkillCategory {
  LANGUAGES_AND_FRAMEWORKS
  TOOLS_AND_PLATFORMS
  PROFESSIONAL
}

model Skill {
  id        String        @id @default(cuid())
  name      String
  category  SkillCategory
  level     Int? // proficiency 0–100, drives the level bar in the UI
  sortOrder Int           @default(0)
}

enum ProjectCategory {
  WEB
  ANDROID
  DESKTOP
  FLUTTER
  PYTHON
  OPEN_SOURCE
  FUTURE
}

enum ProjectStatus {
  COMPLETED
  IN_PROGRESS
  PLANNED
  ARCHIVED
}

model Project {
  id           String          @id @default(cuid())
  slug         String          @unique
  title        String
  tagline      String
  description  String
  category     ProjectCategory
  status       ProjectStatus   @default(COMPLETED)
  featured     Boolean         @default(false)
  technologies String[]
  tags         String[]
  features     String[]
  coverImage   String?
  gallery      String[]
  videoUrl     String?
  githubUrl    String?
  liveUrl      String?
  docsUrl      String?
  startDate    DateTime?
  endDate      DateTime?
  // Android-specific (nullable for other categories)
  playStoreUrl String?
  downloadUrl  String?
  version      String?
  releaseDate  DateTime?
  changelog    String[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([category, status])
}

model Achievement {
  id          String    @id @default(cuid())
  title       String
  issuer      String?
  description String?
  date        DateTime?
  sortOrder   Int       @default(0)
}

model Certification {
  id            String    @id @default(cuid())
  title         String
  issuer        String
  credentialUrl String?
  issueDate     DateTime?
  sortOrder     Int       @default(0)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}
